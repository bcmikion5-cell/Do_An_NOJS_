<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h3">Quản lý Bài viết</h2>
        <button class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Thêm bài viết mới
        </button>
    </div>

    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-body">
            <form class="row g-3">
                <div class="col-md-4">
                    <input type="text" class="form-control" placeholder="Tìm kiếm tên bài viết...">
                </div>
                <div class="col-md-3">
                    <select class="form-select">
                        <option selected>Tất cả danh mục</option>
                        <option>Công nghệ</option>
                        <option>Đời sống</option>
                        <option>Thể thao</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select class="form-select">
                        <option selected>Trạng thái</option>
                        <option>Đã xuất bản</option>
                        <option>Bản nháp</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-outline-secondary w-100">Lọc bài viết</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Hình ảnh</th>
                        <th>Tiêu đề</th>
                        <th>Danh mục</th>
                        <th>Ngày đăng</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="ps-4 text-muted">#102</td>
                        <td><img src="https://via.placeholder.com/60x40" class="rounded" alt="thumb"></td>
                        <td><strong>Cách tối ưu hóa SQL Server cho WinForms</strong></td>
                        <td><span class="badge bg-info text-dark">Lập trình</span></td>
                        <td>16/04/2026</td>
                        <td><span class="badge bg-success">Công khai</span></td>
                        <td class="text-end pe-4">
                            <button class="btn btn-sm btn-outline-primary me-1">Sửa</button>
                            <button class="btn btn-sm btn-outline-danger">Xóa</button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        
        <div class="card-footer bg-white d-flex justify-content-between align-items-center py-3">
            <p class="text-muted small mb-0">Hiển thị 1 - 10 trên tổng số 50 bài viết</p>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item disabled"><a class="page-link" href="#">Trước</a></li>
                    <li class="page-item active"><a class="page-link" href="#">1</a></li>
                    <li class="page-item"><a class="page-link" href="#">2</a></li>
                    <li class="page-item"><a class="page-link" href="#">3</a></li>
                    <li class="page-item"><a class="page-link" href="#">Sau</a></li>
                </ul>
            </nav>
        </div>
    </div>
</div>