<%- include('./partials/header_ad') %>

<div class="container-fluid">
    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h2">Danh sách email mới đăng ký</h1>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-sm">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Email</th>
                    <th>Ngày đăng ký</th>
                </tr>
            </thead>
            <tbody>
                <% subscribers.forEach(sub => { %>
                <tr>
                    <td><%= sub.id %></td>
                    <td><%= sub.email %></td>
                    <td><%= new Date(sub.ngaydangky).toLocaleDateString('vi-VN') %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<%- include('./partials/footer_ad') %>