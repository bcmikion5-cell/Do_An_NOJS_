<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Quản lý bài viết</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">

    <div class="container bg-white mt-5 p-4 shadow-sm rounded border">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="d-flex align-items-center">
                <a href="/admin/dashboard" class="btn btn-outline-secondary me-3 shadow-sm" title="Quay lại">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
                <h2 class="text-primary fw-bold mb-0"><i class="bi bi-newspaper"></i> Quản lý bài viết</h2>
            </div>
            
            <a href="/admin/posts/add" class="btn btn-success px-4 shadow-sm">
                <i class="bi bi-plus-circle"></i> Thêm bài viết mới
            </a>
        </div>

        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th style="width: 50px;" class="text-center">ID</th>
                    <th style="width: 100px;">Ảnh</th>
                    <th>Tiêu đề & Nội dung</th>
                    <th style="width: 150px;">Danh mục</th>
                    <th style="width: 150px;" class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                <% if (posts.length > 0) { %>
                    <% posts.forEach(post => { %>
                    <tr>
                        <td class="text-center text-muted">#<%= post.id %></td>
                        <td>
                            <img src="<%= post.image %>" 
                                 onerror="this.src='https://via.placeholder.com/80x60?text=No+Image'" 
                                 class="img-preview border shadow-sm">
                        </td>
                        <td>
                            <div class="fw-bold text-dark post-title">
                                <%= post.title %>
                            </div>
                            <div class="post-content">
                                <%= post.content %>
                            </div>
                        </td>
                        <td>
                            <span class="badge bg-info text-dark">
                                <i class="bi bi-tag"></i> <%= post.category_name || 'Chưa phân loại' %>
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="btn-group">
                                <a href="/admin/posts/edit/<%= post.id %>" class="btn btn-sm btn-outline-primary" title="Chỉnh sửa">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="/admin/posts/delete/<%= post.id %>" 
                                   class="btn btn-sm btn-outline-danger" 
                                   onclick="return confirm('Bạn có chắc chắn muốn xóa bài viết này?')" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">Chưa có bài viết nào được đăng.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>