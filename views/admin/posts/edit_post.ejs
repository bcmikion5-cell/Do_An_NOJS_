<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Chỉnh sửa bài viết</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        .preview-img {
            max-width: 100%;
            max-height: 200px;
            object-fit: cover;
            border-radius: 8px;
            margin-top: 10px;
            display: block;
        }
    </style>
</head>
<body class="bg-light">

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="d-flex align-items-center mb-4">
                    <a href="/admin/posts" class="btn btn-outline-secondary me-3 shadow-sm">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                    <h2 class="text-primary fw-bold mb-0">
                        <i class="bi bi-pencil-square"></i> Chỉnh sửa bài viết
                    </h2>
                </div>

                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <form action="/admin/posts/edit/<%= post.id %>" method="POST">
                            
                            <div class="mb-4">
                                <label class="form-label fw-semibold text-secondary">Tiêu đề bài viết</label>
                                <input type="text" name="title" class="form-control form-control-lg border-2" 
                                       value="<%= post.title %>" placeholder="Nhập tiêu đề..." required>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-semibold text-secondary">Đường dẫn hình ảnh (URL)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-image"></i></span>
                                    <input type="text" name="image" id="imageInput" class="form-control border-2" 
                                           value="<%= post.image %>" placeholder="https://example.com/image.jpg">
                                </div>
                                <div class="mt-2">
                                    <small class="text-muted d-block mb-2">Xem trước hình ảnh:</small>
                                    <img src="<%= post.image %>" id="imgPreview" class="preview-img border shadow-sm" 
                                         onerror="this.src='https://via.placeholder.com/400x200?text=Link+ảnh+lỗi'">
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-semibold text-secondary">Danh mục</label>
                                <select name="category_id" class="form-select border-2">
                                    <% categories.forEach(cat => { %>
                                        <option value="<%= cat.id %>" <%= cat.id == post.category_id ? 'selected' : '' %>>
                                            <%= cat.name %>
                                        </option>
                                    <% }) %>
                                </select>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-semibold text-secondary">Nội dung chi tiết</label>
                                <textarea name="content" class="form-control border-2" rows="8" 
                                          placeholder="Viết nội dung tại đây..."><%= post.content %></textarea>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-semibold text-secondary">Trạng thái bài viết</label>
                                <select name="status" class="form-select border-2">
                                    <option value="1" <%= post.status == 1 ? 'selected' : '' %>>Công khai (Hiện)</option>
                                    <option value="0" <%= post.status == 0 ? 'selected' : '' %>>Bản nháp (Ẩn)</option>
                                </select>
                            </div>

                            <div class="d-flex justify-content-between align-items-center border-top pt-4">
                                <a href="/admin/posts" class="text-decoration-none text-muted">
                                    <i class="bi bi-x-circle"></i> Hủy thay đổi
                                </a>
                                <button type="submit" class="btn btn-primary px-5 py-2 shadow">
                                    <i class="bi bi-check-lg"></i> Cập nhật ngay
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
                
                <p class="text-center text-muted mt-4 small">ID bài viết: #<%= post.id %></p>
            </div>
        </div>
    </div>

    <script>
        const imageInput = document.getElementById('imageInput');
        const imgPreview = document.getElementById('imgPreview');

        imageInput.addEventListener('input', function() {
            if (this.value) {
                imgPreview.src = this.value;
            } else {
                imgPreview.src = 'https://via.placeholder.com/400x200?text=Chưa+có+ảnh';
            }
        });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>