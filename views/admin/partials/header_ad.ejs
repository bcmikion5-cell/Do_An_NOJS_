<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel - Newsfeed</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body>
    <div class="container-fluid">
    <div class="row">
        <div class="col-md-3 col-lg-2 p-0 bg-dark text-white" style="min-height: 100vh;">
            <div class="p-3 text-center border-bottom border-secondary">
                <h4>Quản Trị</h4>
                <p class="small text-muted">Xin chào, <%= locals.adminName ? adminName : 'Admin' %></p>
            </div>
            <div class="list-group list-group-flush">
                <a href="/admin/dashboard" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">🏠 Bảng điều khiển</a>
                <a href="/admin/users" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">📧 Quản lý người dùng</a>
                <a href="/admin/categories" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">📁 Quản lý Danh mục</a>
                <a href="/admin/posts" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">📝 Quản lý Bài viết</a>
                <a href="/admin/subscribers" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">📧 Quản lý NewsLetter</a>
                <a href="/admin/contacts" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">💬 Quản lý Liên hệ</a>
                <a href="/admin/logout" class="list-group-item list-group-item-action bg-dark text-danger border-0 py-3">Đăng xuất</a>
            </div>
        </div>
        
        <div class="col-md-9 col-lg-10 p-4 bg-light">
</body>
