<div class="container mt-5">
    <div class="row">
        <div class="col-lg-8">
            
            <h1 class="fw-bold mb-3"><%= post.title %></h1>
            
            <div class="text-muted mb-4 d-flex align-items-center">
                <span class="me-3"><i class="fas fa-calendar-alt me-1"></i> <%= new Date(post.ngaydang).toLocaleDateString('vi-VN') %></span>
                <span><i class="fas fa-eye me-1"></i> <%= post.views %> lượt xem</span>
            </div>

            <img src="/img/<%= post.image %>" class="img-fluid w-100 rounded mb-4" alt="<%= post.title %>">

            <div class="post-content mb-5" style="font-size: 1.1rem; line-height: 1.8;">
                <p class="fw-bold text-dark"><%= post.summary %></p>
                <%- post.content %> 
            </div>

            <hr class="my-5">

            <div class="comments-list mb-5">
                <h4 class="fw-bold mb-4 text-uppercase border-bottom pb-2">Bình luận (<%= comments.length %>)</h4>
                
                <% if(comments.length > 0) { %>
                    <% comments.forEach(comment => { %>
                        <div class="d-flex mb-4 p-3 border rounded bg-white shadow-sm">
                            <div class="flex-shrink-0">
                                <img src="https://ui-avatars.com/api/?name=<%= comment.email %>&background=random&color=fff" class="rounded-circle" width="50">
                            </div>
                            <div class="ms-3">
                                <h6 class="fw-bold mb-1 text-primary"><%= comment.email %></h6>
                                <small class="text-muted d-block mb-2">
                                    📅 <%= new Date(comment.ngaybinhluan).toLocaleString('vi-VN') %>
                                </small>
                                <p class="mb-0 text-dark"><%= comment.content %></p>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="text-muted fst-italic">Chưa có bình luận nào. Hãy là người đầu tiên!</p>
                <% } %>
            </div>

            <div class="comment-section bg-light p-4 rounded mb-5">
                <h4 class="mb-4 text-uppercase fw-bold">Để lại bình luận</h4>
                <form action="/comment" method="POST">
                    <input type="hidden" name="post_id" value="<%= post.id %>">
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Email của bạn (*)</label>
                        <input type="email" class="form-control" name="email" placeholder="Nhập email hợp lệ..." required>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Nội dung bình luận (*)</label>
                        <textarea class="form-control" name="content" rows="4" placeholder="Nhập ý kiến của bạn..." required></textarea>
                    </div>
                    
                    <button type="submit" class="btn btn-primary px-4 fw-bold">Gửi bình luận</button>
                </form>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="sticky-top" style="top: 20px;">
                <h4 class="text-uppercase fw-bold text-danger border-bottom pb-2 mb-4">Bài Viết Cùng Loại</h4>
                
                <% if(typeof relatedPosts !== 'undefined' && relatedPosts.length > 0) { %>
                    <% relatedPosts.forEach(rPost => { %>
                        <div class="card mb-4 border-0 shadow-sm">
                            <a href="/single/<%= rPost.id %>">
                                <img src="/img/<%= rPost.image %>" class="card-img-top" alt="<%= rPost.title %>" style="height: 180px; object-fit: cover;">
                            </a>
                            <div class="card-body">
                                <h6 class="card-title fw-bold">
                                    <a href="/single/<%= rPost.id %>" class="text-dark text-decoration-none" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                        <%= rPost.title %>
                                    </a>
                                </h6>
                                <p class="text-muted small mb-0">📅 <%= new Date(rPost.ngaydang).toLocaleDateString('vi-VN') %></p>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="alert alert-light border">Chưa có bài viết cùng loại.</div>
                <% } %>
            </div>
        </div>
        
    </div>
</div>