<%- include('../partials/trending') %>

<div class="container mt-4">
    
    <div class="mb-3 border-bottom pb-2">
        <h3 class="text-danger text-uppercase">Tin Tức Mới Nhất</h3>
    </div>
    
    <div class="row">
        <% if(typeof latestPosts !== 'undefined' && latestPosts.length > 0) { %>
            <% latestPosts.forEach(post => { %>
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <img src="/img/<%= post.image %>" class="card-img-top" alt="<%= post.title %>" style="height: 200px; object-fit: cover;">
                        
                        <div class="card-body">
                            <h5 class="card-title">
                                <a href="/single/<%= post.id %>" class="text-dark text-decoration-none fw-bold"><%= post.title %></a>
                            </h5>
                            
                            <p class="text-muted small mb-2">
                                📅 <%= new Date(post.ngaydang).toLocaleDateString('vi-VN') %>
                            </p>

                            <p class="card-text"><%= post.summary %></p>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-12"><p>Chưa có tin tức mới nào.</p></div>
        <% } %>
    </div>

    <div class="mb-3 mt-5 border-bottom pb-2">
        <h3 class="text-primary text-uppercase">Xem Nhiều Nhất</h3>
    </div>

    <div class="row">
        <% if(typeof trendingPosts !== 'undefined' && trendingPosts.length > 0) { %>
            <% trendingPosts.forEach(post => { %>
                <div class="col-md-6 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="row g-0 h-100">
                            <div class="col-md-4">
                                <img src="/img/<%= post.image %>" class="img-fluid rounded-start h-100 w-100" alt="<%= post.title %>" style="object-fit: cover; min-height: 150px;">
                            </div>
                            
                            <div class="col-md-8">
                                <div class="card-body">
                                   
                                        <a href="/single/<%= post.id %>" class="badge badge-primary text-uppercase font-weight-semi-bold p-2 mr-2"><%= post.title %></a>
                                  
                                 
                                    <a class="text-muted small mb-2">
                                        <%= new Date(post.ngaydang).toLocaleDateString('vi-VN') %>
                                    </a>

                                    <p class="card-text h5"><%= post.summary %></p>
                                    <p class="card-text small"><%= post.content %></p>

                                    <hr>                                  
                                        <small class="ml-3"><i class="far fa-eye mr-2"></i><%= post.views %></small>
                                        <small class="ml-3"><i class="far fa-comment mr-2"></i><%= post.comment %></small>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-12"><p>Chưa có tin tức xem nhiều.</p></div>
        <% } %>
    </div>

</div>