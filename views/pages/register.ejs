<form action="/register" method="POST" class="was-validated border border-5 rounded p-4 m-4 w-50 mx-auto">
    <h3 class="text-center mb-4">Đăng Ký Tài Khoản</h3>

    <div class="form-floating mb-3 mt-3">
        <label>Họ và Tên (Username)</label>
        <input type="text" class="form-control" name="username" placeholder="Nhập tên của bạn" required>
    </div>

    <div class="form-floating mb-3 mt-3">
        <label>Email</label>
        <input type="email" class="form-control" name="email" placeholder="Enter email" required>
    </div>

    <div class="form-floating mt-3 mb-4">
        <label>Mật khẩu (Password)</label>
        <input type="password" class="form-control" name="password" placeholder="Enter password" required>
    </div>

    <div class="d-flex justify-content-center gap-3"> 
        <button type="submit" class="btn btn-primary px-4">Đăng Ký</button>
        <a href="/login" class="btn btn-outline-secondary px-4">Quay lại Đăng Nhập</a>
    </div>
</form>