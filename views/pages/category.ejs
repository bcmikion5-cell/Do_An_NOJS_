<div class="container-fluid mt-5 pt-3">
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <div class="row">
                    <div class="col-12">
                        <div class="section-title">
                            <h4 class="m-0 text-uppercase font-weight-bold">
                                Kết quả: <%= total %> bài viết 
                                <% if(keyword) { %> cho "<%= keyword %>" <% } %>
                            </h4>
                        </div>
                    </div>

                    <% if (listTin.length > 0) { %>
                        <% listTin.forEach(item => { %>
                            <div class="col-lg-6">
                                <div class="position-relative mb-3">
                                    <img class="img-fluid w-100" src="/img/<%= item.image %>" style="height: 250px; object-fit: cover;">
                                    <div class="bg-white border border-top-0 p-4">
                                        <div class="mb-2">
                                            <a class="badge badge-primary text-uppercase font-weight-semi-bold p-2 mr-2" href="/category?id=<%= item.category_id %>">
                                                <%= item.CategoryName %>
                                            </a>
                                            <small><%= item.ngaydang.toLocaleDateString() %></small>
                                        </div>
                                        <a class="h4 d-block mb-3 text-secondary text-uppercase font-weight-bold" href="/single/<%= item.id %>">
                                            <%= item.title %>
                                        </a>
                                        <p class="m-0 text-truncate-2"><%= item.summary %></p>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="col-12">
                            <p class="alert alert-warning">Không tìm thấy bài viết nào phù hợp với yêu cầu của bạn.</p>
                        </div>
                    <% } %>
                </div>

                <div class="row">
                    <div class="col-12">
                        <nav aria-label="Page navigation">
                          <ul class="pagination justify-content-center">
                            <% for(let i = 1; i <= totalPages; i++) { %>
                                <li class="page-item <%= currentPage == i ? 'active' : '' %>">
                                    <a class="page-link" href="/category?page=<%= i %>&search=<%= keyword %>&id=<%= categoryId %>">
                                        <%= i %>
                                    </a>
                                </li>
                            <% } %>
                          </ul>
                        </nav>
                    </div>
                </div>
            </div>

            
        </div>
    </div>
</div>